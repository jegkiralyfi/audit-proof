{
  "$defs": {
    "ArtifactReference": {
      "properties": {
        "artifact_name": {
          "title": "Artifact Name",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "role": {
          "title": "Role",
          "type": "string"
        },
        "media_type": {
          "title": "Media Type",
          "type": "string"
        },
        "generated_by": {
          "default": "audit-proof",
          "title": "Generated By",
          "type": "string"
        },
        "optional": {
          "default": false,
          "title": "Optional",
          "type": "boolean"
        }
      },
      "required": [
        "artifact_name",
        "path",
        "role",
        "media_type"
      ],
      "title": "ArtifactReference",
      "type": "object"
    },
    "CertificateOperationalProfile": {
      "properties": {
        "runner_types": {
          "items": {
            "type": "string"
          },
          "title": "Runner Types",
          "type": "array"
        },
        "runner_families": {
          "items": {
            "type": "string"
          },
          "title": "Runner Families",
          "type": "array"
        },
        "capability_classes": {
          "items": {
            "type": "string"
          },
          "title": "Capability Classes",
          "type": "array"
        },
        "execution_modes": {
          "items": {
            "type": "string"
          },
          "title": "Execution Modes",
          "type": "array"
        },
        "source_kinds": {
          "items": {
            "type": "string"
          },
          "title": "Source Kinds",
          "type": "array"
        },
        "source_modules": {
          "items": {
            "type": "string"
          },
          "title": "Source Modules",
          "type": "array"
        },
        "required_checks": {
          "default": 0,
          "title": "Required Checks",
          "type": "integer"
        },
        "optional_checks": {
          "default": 0,
          "title": "Optional Checks",
          "type": "integer"
        }
      },
      "title": "CertificateOperationalProfile",
      "type": "object"
    },
    "CertificateProvenance": {
      "properties": {
        "checker_bundle_version": {
          "default": "0.1.0",
          "title": "Checker Bundle Version",
          "type": "string"
        },
        "parser_version": {
          "default": "0.1.0",
          "title": "Parser Version",
          "type": "string"
        },
        "model_version": {
          "default": "rule-based-v0",
          "title": "Model Version",
          "type": "string"
        },
        "prompt_bundle_version": {
          "default": "promptless-v0",
          "title": "Prompt Bundle Version",
          "type": "string"
        },
        "policy_version": {
          "default": "unversioned",
          "title": "Policy Version",
          "type": "string"
        },
        "metadata_source": {
          "default": "user-input",
          "title": "Metadata Source",
          "type": "string"
        },
        "generated_at": {
          "format": "date-time",
          "title": "Generated At",
          "type": "string"
        }
      },
      "title": "CertificateProvenance",
      "type": "object"
    },
    "CertificateSummary": {
      "properties": {
        "passed": {
          "default": 0,
          "title": "Passed",
          "type": "integer"
        },
        "warnings": {
          "default": 0,
          "title": "Warnings",
          "type": "integer"
        },
        "failed": {
          "default": 0,
          "title": "Failed",
          "type": "integer"
        },
        "not_applicable": {
          "default": 0,
          "title": "Not Applicable",
          "type": "integer"
        },
        "errors": {
          "default": 0,
          "title": "Errors",
          "type": "integer"
        }
      },
      "title": "CertificateSummary",
      "type": "object"
    },
    "CertificationProfile": {
      "properties": {
        "certification_type": {
          "title": "Certification Type",
          "type": "string"
        },
        "scope_label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scope Label"
        },
        "declared_standards": {
          "items": {
            "$ref": "#/$defs/StandardDeclaration"
          },
          "title": "Declared Standards",
          "type": "array"
        },
        "certification_lanes": {
          "items": {
            "type": "string"
          },
          "title": "Certification Lanes",
          "type": "array"
        },
        "check_standard_index": {
          "additionalProperties": {
            "items": {
              "$ref": "#/$defs/StandardReference"
            },
            "type": "array"
          },
          "title": "Check Standard Index",
          "type": "object"
        }
      },
      "required": [
        "certification_type"
      ],
      "title": "CertificationProfile",
      "type": "object"
    },
    "CheckResult": {
      "properties": {
        "check_id": {
          "title": "Check Id",
          "type": "string"
        },
        "status": {
          "enum": [
            "pass",
            "warning",
            "fail",
            "not_applicable",
            "error"
          ],
          "title": "Status",
          "type": "string"
        },
        "confidence": {
          "default": 0.5,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/EvidenceSpan"
          },
          "title": "Evidence",
          "type": "array"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "runner_metadata": {
          "anyOf": [
            {
              "$ref": "#/$defs/RunnerMetadata"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "standard_refs": {
          "items": {
            "$ref": "#/$defs/StandardReference"
          },
          "title": "Standard Refs",
          "type": "array"
        },
        "details": {
          "additionalProperties": true,
          "title": "Details",
          "type": "object"
        }
      },
      "required": [
        "check_id",
        "status"
      ],
      "title": "CheckResult",
      "type": "object"
    },
    "EvidenceSpan": {
      "properties": {
        "section": {
          "default": "unknown",
          "title": "Section",
          "type": "string"
        },
        "quote": {
          "title": "Quote",
          "type": "string"
        },
        "offset_start": {
          "default": 0,
          "minimum": 0,
          "title": "Offset Start",
          "type": "integer"
        },
        "offset_end": {
          "default": 0,
          "minimum": 0,
          "title": "Offset End",
          "type": "integer"
        }
      },
      "required": [
        "quote"
      ],
      "title": "EvidenceSpan",
      "type": "object"
    },
    "IssuanceDecision": {
      "properties": {
        "status": {
          "default": "issued",
          "enum": [
            "issued",
            "issued_with_warnings",
            "withheld"
          ],
          "title": "Status",
          "type": "string"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        },
        "matched_fail_rules": {
          "items": {
            "type": "string"
          },
          "title": "Matched Fail Rules",
          "type": "array"
        },
        "matched_warning_rules": {
          "items": {
            "type": "string"
          },
          "title": "Matched Warning Rules",
          "type": "array"
        }
      },
      "title": "IssuanceDecision",
      "type": "object"
    },
    "IssuerTrustProfile": {
      "properties": {
        "issuer_mode": {
          "default": "self_hosted",
          "title": "Issuer Mode",
          "type": "string"
        },
        "trust_tier": {
          "default": "self_hosted_non_audited_self_claim",
          "enum": [
            "self_hosted_non_audited_self_claim",
            "self_hosted_repo_matched",
            "self_hosted_release_matched_with_provenance",
            "audited_or_witnessed"
          ],
          "title": "Trust Tier",
          "type": "string"
        },
        "repo_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Repo Url"
        },
        "release_channel": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "stable",
          "title": "Release Channel"
        },
        "release_tag": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Release Tag"
        },
        "release_commit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Release Commit"
        },
        "runtime_commit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Runtime Commit"
        },
        "source_tree_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Tree Hash"
        },
        "release_manifest_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Release Manifest Hash"
        },
        "working_tree_clean": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Working Tree Clean"
        },
        "repo_matches_release": {
          "default": false,
          "title": "Repo Matches Release",
          "type": "boolean"
        },
        "build_provenance_present": {
          "default": false,
          "title": "Build Provenance Present",
          "type": "boolean"
        },
        "container_digest": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Container Digest"
        },
        "red_team_certified": {
          "default": false,
          "title": "Red Team Certified",
          "type": "boolean"
        },
        "external_audit_present": {
          "default": false,
          "title": "External Audit Present",
          "type": "boolean"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "title": "IssuerTrustProfile",
      "type": "object"
    },
    "RunnerMetadata": {
      "properties": {
        "runner_type": {
          "title": "Runner Type",
          "type": "string"
        },
        "runner_family": {
          "default": "generic",
          "title": "Runner Family",
          "type": "string"
        },
        "execution_mode": {
          "default": "deterministic",
          "title": "Execution Mode",
          "type": "string"
        },
        "capabilities": {
          "items": {
            "type": "string"
          },
          "title": "Capabilities",
          "type": "array"
        },
        "implementation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Implementation"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "source_kind": {
          "default": "builtin",
          "title": "Source Kind",
          "type": "string"
        },
        "source_module": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Module"
        }
      },
      "required": [
        "runner_type"
      ],
      "title": "RunnerMetadata",
      "type": "object"
    },
    "StandardDeclaration": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version"
        },
        "standard_family": {
          "default": "reporting-guideline",
          "title": "Standard Family",
          "type": "string"
        },
        "declaration_mode": {
          "default": "full",
          "title": "Declaration Mode",
          "type": "string"
        },
        "modules": {
          "items": {
            "type": "string"
          },
          "title": "Modules",
          "type": "array"
        },
        "applicability": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Applicability"
        }
      },
      "required": [
        "id",
        "label"
      ],
      "title": "StandardDeclaration",
      "type": "object"
    },
    "StandardReference": {
      "properties": {
        "standard_id": {
          "title": "Standard Id",
          "type": "string"
        },
        "modules": {
          "items": {
            "type": "string"
          },
          "title": "Modules",
          "type": "array"
        },
        "applicability": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Applicability"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        }
      },
      "required": [
        "standard_id"
      ],
      "title": "StandardReference",
      "type": "object"
    }
  },
  "properties": {
    "certificate_version": {
      "default": "0.1.0",
      "title": "Certificate Version",
      "type": "string"
    },
    "security_notice": {
      "default": "SANDBOX / PROTOTYPE ONLY \u2014 NOT RED TEAM CERTIFIED. Manual prompt-injection hardening only. Do not treat any certificate, artifact, report, or execution record as a hardened security boundary or production-grade validation guarantee.",
      "title": "Security Notice",
      "type": "string"
    },
    "sandbox_only": {
      "default": true,
      "title": "Sandbox Only",
      "type": "boolean"
    },
    "red_team_certified": {
      "default": false,
      "title": "Red Team Certified",
      "type": "boolean"
    },
    "prompt_injection_protection": {
      "default": "manual-only",
      "title": "Prompt Injection Protection",
      "type": "string"
    },
    "doc_hash": {
      "title": "Doc Hash",
      "type": "string"
    },
    "cert_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cert Hash"
    },
    "timestamp": {
      "format": "date-time",
      "title": "Timestamp",
      "type": "string"
    },
    "domain": {
      "title": "Domain",
      "type": "string"
    },
    "tier": {
      "title": "Tier",
      "type": "string"
    },
    "certification_profile": {
      "anyOf": [
        {
          "$ref": "#/$defs/CertificationProfile"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "title": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Title"
    },
    "doi": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Doi"
    },
    "checks_run": {
      "items": {
        "$ref": "#/$defs/CheckResult"
      },
      "title": "Checks Run",
      "type": "array"
    },
    "summary": {
      "$ref": "#/$defs/CertificateSummary"
    },
    "issuance": {
      "$ref": "#/$defs/IssuanceDecision"
    },
    "provenance": {
      "$ref": "#/$defs/CertificateProvenance"
    },
    "operational_profile": {
      "$ref": "#/$defs/CertificateOperationalProfile"
    },
    "issuer_trust_profile": {
      "$ref": "#/$defs/IssuerTrustProfile"
    },
    "artifact_references": {
      "items": {
        "$ref": "#/$defs/ArtifactReference"
      },
      "title": "Artifact References",
      "type": "array"
    },
    "notes": {
      "default": "",
      "title": "Notes",
      "type": "string"
    }
  },
  "required": [
    "doc_hash",
    "domain",
    "tier",
    "summary"
  ],
  "title": "Certificate",
  "type": "object"
}