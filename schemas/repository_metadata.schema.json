{
  "$defs": {
    "RepositoryMetadataEntry": {
      "properties": {
        "source_check_id": {
          "title": "Source Check Id",
          "type": "string"
        },
        "repository_url": {
          "title": "Repository Url",
          "type": "string"
        },
        "repository_provider": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Repository Provider"
        },
        "fetch_status": {
          "default": "normalized_only",
          "enum": [
            "fetch_disabled",
            "normalized_only",
            "unsupported_provider",
            "fetched",
            "fetch_failed"
          ],
          "title": "Fetch Status",
          "type": "string"
        },
        "normalized_owner": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Normalized Owner"
        },
        "normalized_repo": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Normalized Repo"
        },
        "normalized_full_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Normalized Full Name"
        },
        "api_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Api Url"
        },
        "default_branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default Branch"
        },
        "stars": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stars"
        },
        "archived": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Archived"
        },
        "visibility": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Visibility"
        },
        "license_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "License Name"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "homepage": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Homepage"
        },
        "topics": {
          "items": {
            "type": "string"
          },
          "title": "Topics",
          "type": "array"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        },
        "fetched_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fetched At"
        }
      },
      "required": [
        "source_check_id",
        "repository_url"
      ],
      "title": "RepositoryMetadataEntry",
      "type": "object"
    }
  },
  "properties": {
    "artifact_version": {
      "default": "0.1.0",
      "title": "Artifact Version",
      "type": "string"
    },
    "bundle_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Bundle Id"
    },
    "doc_hash": {
      "title": "Doc Hash",
      "type": "string"
    },
    "domain": {
      "title": "Domain",
      "type": "string"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "repositories": {
      "items": {
        "$ref": "#/$defs/RepositoryMetadataEntry"
      },
      "title": "Repositories",
      "type": "array"
    }
  },
  "required": [
    "doc_hash",
    "domain"
  ],
  "title": "RepositoryMetadataArtifact",
  "type": "object"
}